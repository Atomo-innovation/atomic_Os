# MeshCentral external authentication configuration (template)
#
# Copy this file to `.env` and set NODE_AUTH_API to your Node application's
# external-login endpoint. MeshCentral POSTs { "username", "password" } to it
# when a user that does not exist locally tries to log in.
#
# Leave empty (or remove the line) to completely disable external login.

NODE_AUTH_API=http://localhost:3000/api/auth/external-login

# Gmail SMTP for registration OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tirthkuchara@gmail.com
SMTP_PASS=zztivuvmymkkrsgy
